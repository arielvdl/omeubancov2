# Mobile (Expo public env vars)
# Development: .env is used (loaded by @expo/env when NODE_ENV != production)
# Production: .env.production takes priority (Release builds set NODE_ENV=production)
# Local overrides: .env.production.local (gitignored)
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# RevenueCat (public keys, safe for client)
EXPO_PUBLIC_REVENUECAT_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
