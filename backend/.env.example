DATABASE_URL=postgresql://user:password@localhost:5432/omeubanco
JWT_SECRET=your-jwt-secret-min-32-chars-here
CRON_SECRET=your-cron-secret-min-16
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# Passkey / WebAuthn
# RP_ID = domain do AASA (sem https://)
# RP_ORIGIN = https://RP_ID (pode ser multiplos separados por virgula)
#
# Dev: RP_ID=localhost, RP_ORIGIN=http://localhost:3000
# Prod: RP_ID=omeubanco-api-548984743318.southamerica-east1.run.app
#        RP_ORIGIN=https://omeubanco-api-548984743318.southamerica-east1.run.app
#
# IMPORTANTE para iOS nativo:
# O iOS envia origin como "https://<RP_ID>" no clientDataJSON.
# Se RP_ORIGIN nao incluir esse valor, a verificacao vai falhar.
# Para garantir, inclua ambos separados por virgula se necessario:
#   RP_ORIGIN=https://seu-dominio.run.app
RP_ID=localhost
RP_NAME=O Meu Banco
RP_ORIGIN=http://localhost:3000

# Google OAuth (required for "Entrar com Google")
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# RevenueCat Webhook
REVENUECAT_WEBHOOK_SECRET=

# Sentry (error tracking)
SENTRY_DSN=
