{
  "expo": {
    "name": "O Meu Banco",
    "slug": "omeubanco",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "omeubanco",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#f8f8f5",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/36e73d9b-2c6e-481b-b916-53c4650beeed",
      "fallbackToCacheTimeout": 0,
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.omeubanco-app",
      "appleTeamId": "8TA8YQY457",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDevelopmentRegion": "pt_BR",
        "CFBundleLocalizations": ["pt_BR", "pt_PT", "en"]
      },
      "associatedDomains": [
        "webcredentials:api.omeubanco.xyz",
        "webcredentials:omeubanco-api-548984743318.southamerica-east1.run.app",
        "applinks:omeubanco.xyz"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFD600"
      },
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "omeubanco.xyz",
              "pathPrefix": "/invite"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.omeubanco.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFD600"
        }
      ],
      "expo-secure-store",
      "expo-image-picker",
      [
        "expo-media-library",
        {
          "photosPermission": "O Meu Banco precisa acessar suas fotos para que a criança possa escolher uma imagem da galeria e adicioná-la à sua lista de desejos. Por exemplo, escolher a foto de um brinquedo salva no álbum.",
          "savePhotosPermission": "O Meu Banco precisa salvar imagens na galeria para guardar o comprovante das metas conquistadas pela criança."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "O Meu Banco usa a câmera para que a criança possa tirar uma foto do item desejado (por exemplo, um brinquedo na loja) e adicioná-lo à sua lista de desejos dentro do app."
        }
      ],
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FFD600"
        }
      ],
      "expo-apple-authentication",
      "expo-font",
      "expo-web-browser",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "O Meu Banco usa o Face ID para autenticar o responsável ao entrar na Área dos Pais (onde se gerencia filhos, mesadas, metas e assinatura), como alternativa ao PIN dos pais."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-video",
      "expo-audio",
      [
        "@sentry/react-native",
        {
          "organization": "gotas-ltd",
          "project": "omeubanco-app"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "36e73d9b-2c6e-481b-b916-53c4650beeed"
      }
    },
    "owner": "arieldj"
  }
}
